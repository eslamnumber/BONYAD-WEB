# =============================================================================
# Bonyad web — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit secrets.
#
# All env access in the app MUST go through `src/config/env.ts` (zod-validated).
# No `process.env.X` anywhere else.
# =============================================================================

# -----------------------------------------------------------------------------
# Public — exposed to the client. Never put a secret here.
# -----------------------------------------------------------------------------

# Canonical site URL. Used for metadataBase, sitemap, OG image URLs, robots.txt.
# Locally: http://localhost:3000
# Production: https://bonyad-hub.com (or whatever the final domain is)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend REST API base URL (shared with the legacy RN app).
NEXT_PUBLIC_API_BASE_URL=https://bonyad-app-nyayeditqq-ww.a.run.app/api

# Sentry DSN (public). Leave empty locally → Sentry init no-ops silently.
NEXT_PUBLIC_SENTRY_DSN=

# Analytics key (GA4 / Plausible / etc.). Optional; wire when chosen.
NEXT_PUBLIC_ANALYTICS_KEY=

# -----------------------------------------------------------------------------
# Server-only — NEVER prefix with NEXT_PUBLIC_.
# -----------------------------------------------------------------------------

# Random 32+ char token used by the server-side API proxy route.
SERVER_API_PROXY_TOKEN=replace-me-with-a-random-32-plus-char-string

# Random 32+ char secret used to authenticate the backend → /api/revalidate webhook.
REVALIDATE_SECRET=replace-me-with-a-random-32-plus-char-string

# Upstash Redis (for rate-limiting auth endpoints).
# Leave empty locally → rate-limiter no-ops (logs and allows).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry source-map upload token (optional locally).
SENTRY_AUTH_TOKEN=
